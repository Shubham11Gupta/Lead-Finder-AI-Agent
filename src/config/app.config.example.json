{
  "project_name": "lead-finder-ai-agent",
  "environment": "development",
  "timezone": "Asia/Calcutta",
  "default_region": "India",
  "run_output_dir": "runs",
  "outreach_history_file": "data/outreach_messages_log.json",
  "suppression_file": "data/suppression_list.json",
  "reply_intake_file": "data/reply_intake.json",
  "sources": {
    "serper_enabled": true,
    "serper_api_key": "YOUR_SERPER_API_KEY",
    "serper_queries": [
      {
        "query": "new d2c beauty brand india instagram",
        "category": "beauty",
        "region": "India"
      },
      {
        "query": "new d2c snacks startup india",
        "category": "snacks",
        "region": "India"
      }
    ],
    "serper_gl": "in",
    "serper_hl": "en",
    "serper_num": 10,
    "instagram_input_path": ""
  },
  "outreach": {
    "sender_name": "Founder Name",
    "sender_company": "Trio&Buy"
  },
  "delivery": {
    "mode": "gmail_draft"
  },
  "gmail_drafts": {
    "enabled": true,
    "user_id": "me",
    "oauth_client_id": "YOUR_GOOGLE_OAUTH_CLIENT_ID",
    "oauth_client_secret": "YOUR_GOOGLE_OAUTH_CLIENT_SECRET",
    "oauth_refresh_token": "YOUR_GOOGLE_OAUTH_REFRESH_TOKEN",
    "oauth_access_token": ""
  },
  "send": {
    "enabled": false,
    "smtp_host": "smtp.gmail.com",
    "smtp_port": 587,
    "smtp_username": "your_email@example.com",
    "smtp_password": "app_password_here",
    "from_email": "your_email@example.com",
    "from_name": "Trio&Buy Team",
    "use_starttls": true,
    "use_ssl": false,
    "default_subject": "Quick idea for your brand"
  },
  "inbound_replies": []
}
